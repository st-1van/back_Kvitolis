{
  "kind": "collectionType",
  "collectionName": "festivalis",
  "info": {
    "singularName": "festivali",
    "pluralName": "festivalis",
    "displayName": "фестивалі"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "mainBanner": {
      "type": "component",
      "component": "banners.baneri",
      "repeatable": false
    },
    "aboutTitle": {
      "type": "string"
    },
    "aboutDesc": {
      "type": "text"
    },
    "benefits": {
      "type": "component",
      "component": "festivals.perevagi",
      "repeatable": true
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "dateTitle": {
      "type": "string"
    },
    "dateDesc": {
      "type": "string"
    },
    "price": {
      "type": "component",
      "component": "festivals.price",
      "repeatable": true
    },
    "time": {
      "type": "component",
      "component": "festivals.chas-provedennya",
      "repeatable": true
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "priority": {
      "type": "string",
      "default": "0",
      "required": true
    },
    "showPrice": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "video": {
      "type": "component",
      "component": "festivals.video",
      "repeatable": false
    }
  }
}
