    "desc": {
      "type": "string",
      "required": true
    },
    "img": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "text": {
      "type": "richtext",
      "required": true
    },
    "seo": {
      "type": "component",
